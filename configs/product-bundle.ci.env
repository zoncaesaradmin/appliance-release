# Real CAE/CI bundle template.
# Copy this file only if you want to inspect or edit the generated config
# manually. In normal automation, prefer:
#
#   make ci-product-bundle ...
#
# That entrypoint writes a config like this into WORKDIR and runs the full
# bundle flow in one step.

# ---------------------------------------------------------------------------
# Required Inputs
# These are the values automation usually sets explicitly.
# ---------------------------------------------------------------------------

WORKDIR=/private/tmp/appliance-product-ci
PRODUCT_VERSION=0.1.0
K3S_VERSION=v1.30.4+k3s1
CONTROL_PLANE_IMAGE_REF=internal/control-plane-api:0.1.0
CTL_REPO_SOURCE=https://example.invalid/appliance-ctl.git
RELEASE_INPUT_SOURCE=/ci/inputs/release-input-0.1.0.tar.gz

# ---------------------------------------------------------------------------
# Optional Defaults And Overrides
# Every variable below already has a default in the bundle workflow.
# ---------------------------------------------------------------------------

SAMPLE_MODE=0
INPUTS_DIR=${WORKDIR}/inputs
CTL_REPO_REF=
RELEASE_INPUT_VERSION=
RELEASE_INPUT_FETCH_TEMPLATE=
CHART_VERSION=${PRODUCT_VERSION}
ARGO_VERSION=deferred
OS_VERSION=24.04
VALUES_FILE=
# Advanced override. Normally derived from release-input.
CONTROL_PLANE_IMAGE=
# Advanced override. Normally derived from release-input.
ARGO_CRDS=
K3S_BINARY=
K3S_INSTALL_SCRIPT=
K3S_AIRGAP_IMAGES=
