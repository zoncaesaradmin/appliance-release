# CI defaults for scripts/ci/build-full-bundle.sh.
#
# This is the single CI env file in this repo.
# Keep the stable defaults here. The outer CI script should pass the moving
# inputs at runtime, especially:
# - PRODUCT_VERSION
# - RELEASE_INPUT_SOURCE or RELEASE_INPUT_VERSION
# - K3s artifact source paths/URLs

# ---------------------------------------------------------------------------
# Stable Defaults
# These usually do not change across ordinary CI runs.
# ---------------------------------------------------------------------------

WORKDIR=${TMPDIR:-/tmp}/appliance-product-ci
# Optional. If unset, scripts/ci/build-full-bundle.sh exports the final
# customer-facing files under ${WORK_ROOT}/export.
EXPORT_DIR=
# Set these to the git URLs the build machine should clone from.
# Do not point them at sibling local checkouts for the normal CI flow.
CODE_REPO_SOURCE=
CTL_REPO_SOURCE=
K3S_VERSION=v1.30.4+k3s1
HELM_VERSION=v3.21.1
CONTROL_PLANE_IMAGE_REPOSITORY=internal/control-plane-api
CTL_REPO_REF=
CHART_VERSION=
OS_VERSION=24.04
SAMPLE_MODE=0

# ---------------------------------------------------------------------------
# Runtime Values
# The CI driver script normally sets these when it runs.
# ---------------------------------------------------------------------------

PRODUCT_VERSION=
RELEASE_INPUT_SOURCE=
RELEASE_INPUT_VERSION=
RELEASE_INPUT_FETCH_TEMPLATE=
INPUTS_DIR=${WORKDIR}/inputs
VALUES_FILE=
# Advanced overrides. Leave blank for the normal CI flow.
# If RELEASE_INPUT_SOURCE points at an appliance-code-produced artifact,
# the bundle flow derives the control-plane archive name from release-input.json
# and derives the image tag from codeVersion after the fetch step.
# HELM_VERSION pins the auto-downloaded Linux amd64 Helm binary when HELM_BINARY
# is not explicitly set.
HELM_BINARY=
CONTROL_PLANE_VERSION=
CONTROL_PLANE_IMAGE_REF=
CONTROL_PLANE_IMAGE=
K3S_BINARY=
K3S_AIRGAP_IMAGES=
