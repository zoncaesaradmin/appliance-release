# Runnable sample configuration for `make sample-product-bundle`.
# Copy this file only if you want a fully local sample/demo run.
#
# This file captures every env var the bundle workflow understands, but keeps
# most of them optional by deriving sensible defaults in the script.
# Layout:
# 1. Required Inputs: values a real build must decide
# 2. Optional Defaults And Overrides: safe to leave as-is

# ---------------------------------------------------------------------------
# Required Inputs
# These are the only values a real build generally needs to set.
# ---------------------------------------------------------------------------

# Required. Workspace root for generated downloads, staging, keys, and bundle output.
WORKDIR=/private/tmp/appliance-product-sample

# Required. Product version written into release-input and final bundle names.
PRODUCT_VERSION=0.1.0

# Required. Pinned K3s version for the target appliance release.
K3S_VERSION=v1.30.4+k3s1

# Required. The image reference written into values.yaml and bundle metadata.
CONTROL_PLANE_IMAGE_REF=internal/control-plane-api:0.1.0

# Required. appliance-code source.
# Local path or remote git URL.
CODE_REPO_SOURCE=/Users/zoncaesar/ws/appliance-code

# Required. appliance-ctl source.
# Local path or remote git URL.
CTL_REPO_SOURCE=/Users/zoncaesar/ws/appliance-ctl

# ---------------------------------------------------------------------------
# Optional Defaults And Overrides
# Every variable below has a built-in default. Leave them as-is unless you need
# to override the default behavior for a specific environment.
# ---------------------------------------------------------------------------

# Default: 1 for this runnable sample config.
# Set to 0 for a real build with prepared input artifacts.
SAMPLE_MODE=1

# Default: ${WORKDIR}/inputs
# Real build inputs are looked up under this directory unless overridden below.
INPUTS_DIR=${WORKDIR}/inputs

# Default when blank:
# - if CODE_REPO_SOURCE is a local path, use that checkout directly
# - if CODE_REPO_SOURCE is a git URL, clone its default branch
CODE_REPO_REF=

# Default when blank:
# - if CTL_REPO_SOURCE is a local path, use that checkout directly
# - if CTL_REPO_SOURCE is a git URL, clone its default branch
CTL_REPO_REF=

# Default: PRODUCT_VERSION
CHART_VERSION=${PRODUCT_VERSION}

# Default: deferred
ARGO_VERSION=deferred

# Default: 24.04
OS_VERSION=24.04

# Default: keep the generated minimal values file.
VALUES_FILE=

# Default: blank
# Optional manifest metadata override.
SUPPORTED_UPGRADE_SOURCE=

# Default: blank
# Optional additional evidence directories copied into release-input.
SBOM_DIR=
PROVENANCE_DIR=
NOTICES_DIR=
TESTS_DIR=

# Default when blank: ${INPUTS_DIR}/control-plane-api-${PRODUCT_VERSION}.tar
CONTROL_PLANE_IMAGE=

# Default when blank: ${INPUTS_DIR}/argo-crds.yaml
ARGO_CRDS=

# Default when blank: ${INPUTS_DIR}/k3s
K3S_BINARY=

# Default when blank: ${INPUTS_DIR}/install.sh
K3S_INSTALL_SCRIPT=

# Default when blank: ${INPUTS_DIR}/k3s-airgap-images-amd64.tar.zst
K3S_AIRGAP_IMAGES=
