# Sample single-command bundle build configuration.
# Copy this file, then edit only the small set of values below.

WORKDIR=/private/tmp/appliance-product-sample
SAMPLE_MODE=1

# Code repo source: local path or remote git URL. The orchestrator always clones it.
CODE_REPO_SOURCE=/Users/zoncaesar/ws/appliance-code
CODE_REPO_REF=

# zonctl source repo: local path or remote git URL. The orchestrator clones
# and builds the CLI from here.
CTL_REPO_SOURCE=/Users/zoncaesar/ws/appliance-ctl
CTL_REPO_REF=

PRODUCT_VERSION=0.1.0
K3S_VERSION=v1.30.4+k3s1
CHART_VERSION=0.1.0
ARGO_VERSION=deferred
OS_VERSION=24.04

# The image reference written into values and bundle metadata.
CONTROL_PLANE_IMAGE_REF=internal/control-plane-api:0.1.0

INPUTS_DIR=${WORKDIR}/inputs
CONTROL_PLANE_IMAGE=${INPUTS_DIR}/control-plane-api-0.1.0.tar
ARGO_CRDS=${INPUTS_DIR}/argo-crds.yaml
K3S_BINARY=${INPUTS_DIR}/k3s
K3S_INSTALL_SCRIPT=${INPUTS_DIR}/install.sh
K3S_AIRGAP_IMAGES=${INPUTS_DIR}/k3s-airgap-images-amd64.tar.zst

# Optional. If omitted, the orchestrator keeps the generated minimal values file.
VALUES_FILE=

# Optional additional evidence directories for release-input production.
SBOM_DIR=
PROVENANCE_DIR=
NOTICES_DIR=
TESTS_DIR=
