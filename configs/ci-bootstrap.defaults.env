# Optional defaults for scripts/ci/run-product-bundle.sh.
#
# Edit this file if your CI almost always clones the same appliance-ctl
# repo/ref, so you don't have to pass it on every run.
#
# If these values are left blank, the script falls back to sibling directories:
#   ../appliance-ctl

CTL_REPO_SOURCE_DEFAULT=
CTL_REPO_REF_DEFAULT=
