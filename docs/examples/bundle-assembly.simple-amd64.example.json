{
  "schemaVersion": 1,
  "bundleVersion": "2.4.0",
  "releaseInputDir": "/absolute/path/to/release-input",
  "bundleDir": "/absolute/path/to/out/appliance-2.4.0-bundle",
  "signingKeyId": "release-signing-key",
  "signingPrivateKeyPath": "/absolute/path/to/keys/release-signing.key",
  "hostBaseline": {
    "os": "ubuntu",
    "osVersion": "24.04",
    "arch": "amd64"
  },
  "entries": [
    {
      "sourcePath": "/absolute/path/to/appliance-ctl/bin/zonctl",
      "targetPath": "zonctl",
      "component": "appliance",
      "executable": true
    },
    {
      "sourcePath": "/absolute/path/to/staging/k3s",
      "targetPath": "k3s/binary/k3s",
      "component": "k3s-binary",
      "executable": true
    },
    {
      "sourcePath": "/absolute/path/to/staging/install.sh",
      "targetPath": "k3s/install/install.sh",
      "component": "k3s-install",
      "executable": true
    },
    {
      "sourcePath": "/absolute/path/to/staging/k3s-airgap-images-amd64.tar.zst",
      "targetPath": "k3s/images/k3s-airgap-images-amd64.tar.zst",
      "component": "k3s-images"
    },
    {
      "sourcePath": "/absolute/path/to/staging/control-plane-api-<version>.tar",
      "targetPath": "oci-images/control-plane-api-<version>.tar",
      "component": "oci-images",
      "imageReference": "internal/control-plane-api:<version>"
    },
    {
      "sourcePath": "/absolute/path/to/release-input/appliance-chart-2.4.0.tgz",
      "targetPath": "charts/appliance-chart-2.4.0.tgz",
      "component": "chart"
    },
    {
      "sourcePath": "/absolute/path/to/staging/values-minimal.yaml",
      "targetPath": "configuration/values.yaml",
      "component": "configuration"
    }
  ]
}
