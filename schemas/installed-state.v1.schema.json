{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://appliance-release/schemas/installed-state.v1.schema.json",
  "title": "InstalledState",
  "description": "Atomic on-host journal record of the exact installed state, written after every lifecycle transaction. Backs status, verify, upgrade compatibility checks, and K3s ownership decisions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "applianceInstanceId",
    "installedVersion",
    "installedReleaseId",
    "components",
    "k3sOwnership",
    "lastOperation",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "applianceInstanceId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier for this host installation, generated on first install."
    },
    "installedVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$"
    },
    "installedReleaseId": { "type": "string", "minLength": 1 },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "required": ["k3sVersion", "chartVersion", "argoVersion"],
      "properties": {
        "k3sVersion": { "type": "string", "minLength": 1 },
        "chartVersion": { "type": "string", "minLength": 1 },
        "argoVersion": { "type": "string", "minLength": 1 }
      }
    },
    "k3sOwnership": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owned", "ownerApplianceVersion"],
      "properties": {
        "owned": { "const": true },
        "ownerApplianceVersion": { "type": "string", "minLength": 1 }
      }
    },
    "lastOperation": { "$ref": "#/$defs/operation" },
    "history": {
      "type": "array",
      "items": { "$ref": "#/$defs/operation" }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "status", "transactionId", "startedAt"],
      "properties": {
        "type": {
          "enum": [
            "install",
            "upgrade",
            "repair",
            "backup",
            "restore",
            "uninstall",
            "factory-reset"
          ]
        },
        "status": {
          "enum": ["in-progress", "completed", "failed", "rolled-back"]
        },
        "transactionId": { "type": "string", "minLength": 1 },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "sourceVersion": {
          "type": "string",
          "description": "Set for upgrade operations: the version upgraded from."
        },
        "targetVersion": {
          "type": "string",
          "description": "Set for upgrade operations: the version upgraded to."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "completed" } },
            "required": ["status"]
          },
          "then": { "required": ["completedAt"] }
        }
      ]
    }
  }
}
